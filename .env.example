# Environment Configuration Example
# Copy this file to .env and adjust values for your environment
# IMPORTANT: Never commit .env to version control!

# MQTT Broker Configuration
MQTT_BROKER=mqtt-broker
MQTT_PORT=1883

# Model and Data Paths
MODEL_PATH=/app/data/model_artifacts
DATA_PATH=/app/data

# Logging Configuration
LOG_LEVEL=INFO

# Scheduler Configuration (cron format)
TRAINING_SCHEDULE=0 2 * * *           # Daily at 2:00 AM
MONITORING_SCHEDULE=*/15 * * * *      # Every 15 minutes
RECAP_SCHEDULE=0 8 * * *              # Daily at 8:00 AM

# Feature Engineering Settings
WINDOW_SIZE=30
NORMALIZATION_METHOD=minmax

# Model Training Parameters
LEARNING_RATE=0.001
BATCH_SIZE=32
EPOCHS=100
LSTM_LAYERS=2
LSTM_HIDDEN_SIZE=64
DROPOUT_RATE=0.3

# Uncertainty Quantification
MC_DROPOUT_SAMPLES=50
CONFIDENCE_LEVEL=0.95

# Risk Engine Thresholds
RISK_THRESHOLD_CRITICAL=0.8
RISK_THRESHOLD_HIGH=0.6
RISK_THRESHOLD_MEDIUM=0.4

# Cost Parameters
EARLY_MAINTENANCE_COST=1000        # Cost of preventive maintenance
FAILURE_COST=10000                  # Cost of unplanned failure
TIME_DISCOUNT_RATE=0.02             # Discount rate for economic calculations

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Development/Testing
DEBUG=False
TEST_MODE=False

