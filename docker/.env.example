# ======================================
# Risk-Aware AI Platform Configuration
# ======================================

# MQTT Broker Configuration
MQTT_BROKER=mqtt-broker
MQTT_PORT=1883

# Simulator Configuration
OUTPUT_TOPIC=raw/sensors
SIMULATION_SPEED=1.0

# Data Ingestion Configuration
INPUT_TOPIC=raw/sensors
OUTPUT_TOPIC_INGESTION=validated/data

# Feature Engineering Configuration
INPUT_TOPIC_FE=validated/data
OUTPUT_TOPIC_FE=processed/features

# Uncertainty Configuration
INPUT_TOPIC_UQ=predictions/rul
OUTPUT_TOPIC_UQ=predictions/uncertainty
MODEL_PATH=/app/data/model_artifacts

# Risk Engine Configuration
INPUT_TOPIC_RISK=predictions/uncertainty
OUTPUT_TOPIC_RISK=decisions/risk

# Monitoring Configuration
METRICS_TOPIC=monitoring/metrics

# Training Configuration
MODEL_OUTPUT_PATH=/app/data/model_artifacts

# Scheduler Configuration
TRAINING_SCHEDULE=0 2 * * *  # Every day at 2 AM
MONITORING_SCHEDULE=*/15 * * * *  # Every 15 minutes

# API Configuration
LOG_LEVEL=INFO
ENVIRONMENT=production

# Optional: Database Configuration (for future use)
# DATABASE_URL=postgresql://user:password@db:5432/risk_aware

